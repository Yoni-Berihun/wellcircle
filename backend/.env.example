# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wellatribe

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT
JWT_SECRET=your_secret_key_here_generate_with_openssl
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Telebirr Payment
TELEBIRR_MERCHANT_CODE=your_merchant_code
TELEBIRR_APP_KEY=your_app_key
TELEBIRR_NOTIFY_URL=https://your-domain.com/api/payments/telebirr/callback

# M-Pesa Daraja
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key

# Environment
ENVIRONMENT=development
DEBUG=True
