# ===========================================
# Well Circle Backend — Environment Variables
# ===========================================

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Super Admin — comma-separated Telegram IDs
SUPER_ADMIN_TELEGRAM_IDS=123456789

# Bot API Key — shared secret between bot service and backend
BOT_API_KEY=generate_a_random_secret_key

# Payment - Telebirr (Primary - Ethiopia)
TELEBIRR_MERCHANT_CODE=
TELEBIRR_APP_KEY=
TELEBIRR_APP_SECRET=
TELEBIRR_NOTIFY_URL=https://your-render-url.onrender.com/api/payments/telebirr/callback

# Payment - M-Pesa Daraja (Secondary)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-render-url.onrender.com/api/payments/mpesa/callback

# Frontend URL (Vercel deployment)
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
DEBUG=True
